class Solution {
    public int[] findOrder(int V, int[][] prerequisites) {

        List<List<Integer>> adj = new ArrayList<>();

        for (int i = 0; i < V; i++) {
            adj.add(new ArrayList<>());
        }

        int[] ind = new int[V];

        for (int[] it : prerequisites) {
            int u = it[0];
            int v = it[1];

            adj.get(v).add(u);
            ind[u]++;
        }

        Queue<Integer> q = new LinkedList<>();

        for (int i = 0; i < V; i++) {
            if (ind[i] == 0) {
                q.offer(i);
            }
        }

        List<Integer> list = new ArrayList<>();

        while (!q.isEmpty()) {

            int node = q.poll();
            list.add(node);

            for (int it : adj.get(node)) {

                ind[it]--;

                if (ind[it] == 0) {
                    q.offer(it);
                }
            }
        }

        // Cycle exists
        if (list.size() != V) {
            return new int[0];
        }

        int[] ans = new int[V];

        for (int i = 0; i < V; i++) {
            ans[i] = list.get(i);
        }

        return ans;
    }
}
